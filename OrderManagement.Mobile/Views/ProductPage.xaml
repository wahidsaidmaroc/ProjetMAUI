<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderManagement.Mobile.Views.ProductPage"
              Title="Produits">

    <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,Auto,*">

        <Label Text="Gestion des produits"
               Style="{StaticResource SectionTitle}" />

        <HorizontalStackLayout Grid.Row="1" Spacing="10" Margin="0,12,0,8">
            <Label Text="Catalogue Amazon style"
                   Style="{StaticResource SectionSubtitle}"
                   VerticalOptions="Center" />
            <Button Text="Voir mon panier"
                    BackgroundColor="{StaticResource AmazonBlue}"
                    TextColor="White"
                    Clicked="OnGoCartClicked" />
        </HorizontalStackLayout>

        <ActivityIndicator Grid.Row="2"
                           Margin="0,12,0,8"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#4F46E5" />

        <Label Grid.Row="3"
               Text="{Binding ErrorMessage}"
               TextColor="#B91C1C"
               FontAttributes="Italic"
               Margin="0,0,0,8" />

        <CollectionView Grid.Row="4"
                        ItemsSource="{Binding Products}">
            <CollectionView.EmptyView>
                <Label Text="Aucun produit disponible."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#6B7280" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                        <Frame Style="{StaticResource AmazonCard}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AmazonText}" />
                            <Label Text="{Binding Description}"
                                   Style="{StaticResource SectionSubtitle}" />
                            <Label Text="{Binding Price, StringFormat='Prix: {0} MAD'}"
                                   TextColor="{StaticResource AmazonBlue}" />
                            <Button Text="Ajouter au panier"
                                    Clicked="OnAddToCartClicked"
                                    CommandParameter="{Binding .}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>




