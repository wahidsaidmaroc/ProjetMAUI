<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderManagement.Mobile.Views.CategoryPage"
              Title="Catégories">

    <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,*">

        <Label Text="Menu des catégories"
               Style="{StaticResource SectionTitle}" />

        <ActivityIndicator Grid.Row="1"
                           Margin="0,12,0,8"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#4F46E5" />

        <Label Grid.Row="2"
               Text="{Binding ErrorMessage}"
               TextColor="#B91C1C"
               FontAttributes="Italic"
               Margin="0,0,0,8" />

        <CollectionView Grid.Row="3"
                         ItemsSource="{Binding Categories}"
                         SelectionMode="Single"
                         SelectionChanged="OnCategorySelectionChanged">
            <CollectionView.EmptyView>
                <Label Text="Aucune catégorie disponible."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#6B7280" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,12"
                           Padding="16"
                           CornerRadius="14"
                           HasShadow="True"
                           BorderColor="#E5E7EB"
                           BackgroundColor="#F9FAFB">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Label Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="#4B5563" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>