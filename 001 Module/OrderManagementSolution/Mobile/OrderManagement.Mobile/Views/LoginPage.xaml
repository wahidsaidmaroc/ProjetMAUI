<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OrderManagement.Mobile.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Connexion">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,30"
            Spacing="25"
            VerticalOptions="Center">

            <!-- Logo / Icône -->
 
                <Image
                    Source="dotnet_bot.png"
                    Aspect="AspectFit"
                    HeightRequest="60"
                    WidthRequest="60" />
      

            <!-- Titre -->
            <VerticalStackLayout Spacing="5">
                <Label
                    Text="Order Management"
                    FontSize="28"
                    TextColor="#1F2937"
                    HorizontalOptions="Center" />

                <Label
                    Text="Connexion à l'application"
                    FontSize="15"
                    TextColor="#6B7280"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Formulaire -->


                <VerticalStackLayout Spacing="18">

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Email"
                            FontSize="14"
                            TextColor="#374151" />

                
                            <Entry
                                x:Name="EmailEntry"
                                Placeholder="exemple@email.com"
                                Keyboard="Email"
                                TextColor="#111827"
                                PlaceholderColor="#9CA3AF" />
             
                    </VerticalStackLayout>

                    <!-- Mot de passe -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Mot de passe"
                            FontSize="14"
                            TextColor="#374151" />

                        
                            <Entry
                                x:Name="PasswordEntry"
                                Placeholder="********"
                                IsPassword="True"
                                TextColor="#111827"
                                PlaceholderColor="#9CA3AF" />
               
                    </VerticalStackLayout>

                    <!-- Se souvenir de moi -->
                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="RememberMeCheckBox" />
                        <Label
                            Text="Se souvenir de moi"
                            VerticalOptions="Center"
                            FontSize="14"
                            TextColor="#4B5563" />
                    </HorizontalStackLayout>

                    <!-- Message erreur -->
                    <Label
                        x:Name="ErrorLabel"
                        Text=""
                        TextColor="Red"
                        FontSize="13"
                        IsVisible="False" />

                    <!-- Bouton connexion -->
                    <Button
                        Text="Se connecter"
                        BackgroundColor="#5B4CF0"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="50"
                        Clicked="OnLoginClicked" />

                    <!-- Mot de passe oublié -->
                    <Label
                        Text="Mot de passe oublié ?"
                        FontSize="13"
                        TextColor="#5B4CF0"
                        HorizontalOptions="Center" />

                </VerticalStackLayout>
     

            <!-- Bas de page -->
            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="5">
                <Label
                    Text="Pas de compte ?"
                    FontSize="14"
                    TextColor="#6B7280" />
                <Label
                    Text="Créer un compte"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="#5B4CF0" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>